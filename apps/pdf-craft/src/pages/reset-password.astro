---
import Layout from "../layouts/Layout.astro";
import ResetPasswordForm from "../components/views/ResetPasswordForm";
import "../styles/auth.css";

const oobCode = Astro.url.searchParams.get("oobCode");
---

<Layout title="Reset password — PDF Craft" noindex={true}>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-header">
        <h1 class="auth-title">Choose a new password</h1>
        <p class="auth-subtitle">
          Make it something strong you haven't used before.
        </p>
      </div>

      <ResetPasswordForm oobCode={oobCode} client:only />

      <p class="auth-footer-link">
        Remember it? <a href="/signin">Back to sign in</a>
      </p>
    </div>
  </div>
</Layout>
