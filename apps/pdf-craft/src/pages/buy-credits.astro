---
import Layout from "../layouts/Layout.astro";
import { Pricing } from "../components/slices";
import "../styles/pricing.css";
---

<Layout
  title="Buy Credits — Riqa"
  description="Three simple credit packs for PDF tools. Buy once, use anytime. No subscription, no expiry. Merge, protect, convert and unlock PDFs."
>
  <div class="pricing-page">
    <div class="pricing-header">
      <h1 class="pricing-title">Simple, pay-as-you-go pricing</h1>
      <p class="pricing-subtitle">
        Buy credits and use them for any operation. No subscription, no expiry.
      </p>
    </div>
    <div class="pricing-grid">
      <Pricing client:load />
    </div>
  </div>
</Layout>

