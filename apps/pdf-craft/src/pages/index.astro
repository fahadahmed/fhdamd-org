---
import React, { createElement as h } from "react";
import Layout from "../layouts/Layout.astro";
import { Pricing } from "../components";
import { iconMap, deriveVariant } from "../components/slices/Operations/Operations";
import { fetchCms } from "../utils/lib/cms";
import { type Faq, type Operation } from "../utils";
import {
  Hero,
  Container,
  Section,
  SectionHeader,
  AutoGrid,
  OpCard,
  StepCard,
  Testimonial,
  Accordion,
  DarkStrip,
  Button,
} from "@fhdamd/threads";

type FaqResponse = { data: { allFaqs: Faq[] } };
type OperationsResponse = { data: { allOperations: Operation[] } };

const [faqResponse, operationsResponse] = await Promise.all([
  fetchCms<FaqResponse>("faqs"),
  fetchCms<OperationsResponse>("operations"),
]);

const faqs = faqResponse.data.allFaqs;
const operations: Operation[] = [...operationsResponse.data.allOperations]
  .sort((a, b) => a.sortOrder - b.sortOrder);
const faqItems = faqs.map(({ title, content }) => ({
  question: title,
  answer: content,
}));

/* Build all React elements with createElement in the frontmatter
   so Astro's template parser never sees raw JSX inside {} expressions */
const heroSubheading = h(
  "span",
  null,
  h("em", null, "Beautifully honest"),
  " pricing.",
);
const heroActions = h(
  "div",
  {
    style: {
      display: "flex",
      gap: "var(--th-space-3)",
      flexWrap: "wrap" as const,
    },
  },
  h(
    Button as any,
    { variant: "solid-terra", size: "lg", href: "/signup" },
    "Get started free",
  ),
  h(
    Button as any,
    { variant: "ghost", size: "lg", href: "/#tools" },
    "See all tools",
  ),
);

const titleOperations = h(
  "span",
  null,
  "Everything your ",
  h("em", null, "documents"),
  " need",
);
const titleHowItWorks = h(
  "span",
  null,
  "Up and running ",
  h("em", null, "in three steps"),
);
const titlePricing = h(
  "span",
  null,
  "Simple, ",
  h("em", null, "honest"),
  " credits",
);
const titleTestimonials = h(
  "span",
  null,
  "Trusted by people who value their ",
  h("em", null, "time"),
);
const titleFaq = h(
  "span",
  null,
  "Frequently asked ",
  h("em", null, "questions"),
);
const ctaHeading = h(
  "span",
  null,
  "No subscription.",
  h("br", null),
  " Just ",
  h("em", null, "results"),
  ".",
);
const ctaAction = h(
  Button as any,
  { variant: "solid-terra", size: "lg", href: "/signup" },
  "Get started — it's free",
) as React.ReactNode;

const ss = { marginBottom: "var(--th-space-8)" }; // shared section style
---

<Layout
  title="PDF-Craft — Simple PDF Tools. Pay only for what you use."
  description="Merge, protect, convert and unlock PDF documents in seconds. Buy credits once — pay only for what you use, no subscriptions, no expiry."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "PDF-Craft",
      "url": "https://pdf-craft.app",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Merge, protect, convert and unlock PDF documents in seconds. Buy credits once — pay only for what you use, no subscriptions, no expiry.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free to sign up. Pay per use with credits that never expire."
      }
    })} />
  </Fragment>
  <!-- HERO -->
  <Container>
    <Hero
      eyebrow="PDF tools that respect your time"
      heading="Simple PDF tools."
      subheading={heroSubheading}
      body="Merge, protect, convert and unlock PDF documents in seconds. Buy credits once — pay only for what you use, no subscriptions, no expiry."
      chips={[
        "No subscription",
        "Credits never expire",
        "Files processed securely",
        "Any device",
      ]}
      actions={heroActions}
    />
  </Container>

  <!-- OPERATIONS -->
  <section
    id="tools"
    style="border-top:1px solid var(--th-color-border-default)"
  >
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow="PDF operations"
          title={titleOperations}
          intro="Four tools live now. Split, compress, sign and AI-powered summaries are all coming soon."
          style={ss}
        />
        <div class="op-grid">
          {operations.map((op, i) => (
            <div class={op.active ? "op-live" : ""}>
              <OpCard
                name={op.title}
                description={op.detail}
                credits={op.creditCost}
                href={op.active ? op.actionRoute : undefined}
                ctaLabel={op.actionLabel}
                icon={iconMap[op.iconKey]}
                iconVariant={deriveVariant(op, i)}
                status={op.active ? "live" : "soon"}
              />
            </div>
          ))}
        </div>
      </Section>
    </Container>
  </section>

  <!-- HOW IT WORKS -->
  <section
    id="how-it-works"
    style="border-top:1px solid var(--th-color-border-default)"
  >
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow="How it works"
          title={titleHowItWorks}
          style={ss}
        />
        <AutoGrid minColWidth="240px" gap={4}>
          <StepCard
            number="01"
            title="Create a free account"
            body="Sign up in seconds. No credit card required. New accounts include a small credit balance to try the tools straight away."
          />
          <StepCard
            number="02"
            title="Buy a credit pack"
            body="Three simple packs to choose from. Credits never expire and work across every operation. Pay once, use whenever you need."
          />
          <StepCard
            number="03"
            title="Process your documents"
            body="Upload, pick your operation, download. The exact credit cost is shown before you confirm — no surprises, ever."
          />
        </AutoGrid>
      </Section>
    </Container>
  </section>

  <!-- PRICING -->
  <section
    id="pricing"
    style="border-top:1px solid var(--th-color-border-default)"
  >
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow="Pricing"
          title={titlePricing}
          intro="Buy once, use anytime. No monthly fees. No usage caps. Credits never expire."
          style={ss}
        />
        <Pricing client:load />
      </Section>
    </Container>
  </section>

  <!-- TESTIMONIALS -->
  <section style="border-top:1px solid var(--th-color-border-default)">
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow="What people say"
          title={titleTestimonials}
          style={ss}
        />
        <AutoGrid minColWidth="280px" gap={4}>
          <Testimonial
            quote="Finally, a PDF tool that's honest about pricing. I pay only when I actually use it — no subscriptions, no surprises."
            attribution="Samia Akhtar · Senior Claims Consultant"
          />
          <Testimonial
            quote="The credit-based pay-per-use model is incredibly transparent. I know exactly what each action costs before I click."
            attribution="Brendan Lawrie · Partner, Big 4 Consultancy"
          />
          <Testimonial
            quote="Most PDF tools feel bloated. This one does exactly what it promises, charges fairly, and gets out of the way."
            attribution="Sean Kempen · Real Estate Agent"
          />
          <Testimonial
            quote="Clean interface, no learning curve. I merged and converted my files in seconds without reading a single guide."
            attribution="Patricia Widjojo · Paralegal"
          />
        </AutoGrid>
      </Section>
    </Container>
  </section>

  <!-- FAQ -->
  <section id="faq" style="border-top:1px solid var(--th-color-border-default)">
    <Container>
      <Section size="md">
        <SectionHeader eyebrow="FAQ" title={titleFaq} style={ss} />
        <div style="max-width:680px">
          <Accordion client:load items={faqItems} defaultOpenIndex={0} />
        </div>
      </Section>
    </Container>
  </section>

  <!-- CTA STRIP -->
  <section style="border-top:1px solid var(--th-color-border-default)">
    <Container>
      <Section size="md">
        <DarkStrip
          eyebrow="Ready to get started"
          heading={ctaHeading}
          body="Create a free account and process your first PDF in under a minute."
          align="center"
          actions={ctaAction}
        />
      </Section>
    </Container>
  </section>
</Layout>

<style is:global>
  /* OpCard grid — matches the reference HTML breakpoints exactly */
  .op-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  /* Live ops span 2 columns on desktop */
  .op-live {
    grid-column: span 2;
  }

  /* Tablet — collapse to 2-column grid, live cards still span 2 */
  @media (max-width: 900px) {
    .op-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .op-live {
      grid-column: span 2;
    }
  }

  /* Mobile — single column, everything full width */
  @media (max-width: 480px) {
    .op-grid {
      grid-template-columns: 1fr;
    }
    .op-live {
      grid-column: span 1;
    }
  }
</style>
