---
import React, { createElement as h } from "react";
import Layout from "../layouts/Layout.astro";
import { Pricing } from "../components";
import {
  iconMap,
  deriveVariant,
} from "../components/slices/Operations/Operations";
import { fetchCms } from "../utils/lib/cms";
import {
  type Faq,
  type Operation,
  type Testimonial,
  type SectionHeader as SectionHeaderData,
  type HeroData,
  type Step,
  titleToReact,
  indexSectionHeaders,
} from "../utils";
import {
  Hero,
  Container,
  Section,
  SectionHeader,
  AutoGrid,
  OpCard,
  StepCard,
  Testimonial as TestimonialCard,
  Accordion,
  DarkStrip,
  Button,
} from "@fhdamd/threads";

type HomePageResponse = {
  data: {
    allHeros: HeroData[];
    allFaqs: Faq[];
    allOperations: Operation[];
    allTestimonials: Testimonial[];
    allSectionHeaders: SectionHeaderData[];
    allSteps: Step[];
  };
};

const { data } = await fetchCms<HomePageResponse>("homePage");
const faqs = data.allFaqs;
const operations: Operation[] = [...data.allOperations].sort(
  (a, b) => a.sortOrder - b.sortOrder,
);
const faqItems = faqs.map(({ title, content }) => ({
  question: title,
  answer: content,
}));
const testimonials: Testimonial[] = [...data.allTestimonials].sort((a, b) =>
  a._createdAt.localeCompare(b._createdAt),
);
const sh = indexSectionHeaders(data.allSectionHeaders);
const hero = data.allHeros[0];
const steps: Step[] = [...data.allSteps];
/* Build all React elements with createElement in the frontmatter
   so Astro's template parser never sees raw JSX inside {} expressions */
const heroSubheading = hero.subheading
  ? h("span", null, ...titleToReact(hero.subheading))
  : undefined;
const heroActions = h(
  "div",
  {
    style: {
      display: "flex",
      gap: "var(--th-space-3)",
      flexWrap: "wrap" as const,
    },
  },
  h(
    Button as any,
    { variant: "solid-terra", size: "lg", href: hero.primaryCtaHref },
    hero.primaryCtaLabel,
  ),
  hero.secondaryCtaLabel &&
    h(
      Button as any,
      { variant: "ghost", size: "lg", href: hero.secondaryCtaHref },
      hero.secondaryCtaLabel,
    ),
);

const ctaHeading = h(
  "span",
  null,
  "No subscription.",
  h("br", null),
  " Just ",
  h("em", null, "results"),
  ".",
);
const ctaAction = h(
  Button as any,
  { variant: "solid-terra", size: "lg", href: "/signup" },
  "Get started",
) as React.ReactNode;

const borderStyle = "border-top:1px solid var(--th-color-border-default)";
const ss = { marginBottom: "var(--th-space-8)" }; // shared section style
---

<Layout
  title="Riqa — Simple PDF Tools. Pay only for what you use."
  description="Merge, protect, convert and unlock PDF documents in seconds. Buy credits once — pay only for what you use, no subscriptions, no expiry."
>
  <Fragment slot="head">
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Riqa",
        url: "https://riqa.app",
        applicationCategory: "BusinessApplication",
        operatingSystem: "Web",
        description:
          "Merge, protect, convert and unlock PDF documents in seconds. Buy credits once — pay only for what you use, no subscriptions, no expiry.",
        offers: {
          "@type": "Offer",
          price: "0",
          priceCurrency: "USD",
          description:
            "Free to sign up. Pay per use with credits that never expire.",
        },
      })}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqItems.map(({ question, answer }) => ({
          "@type": "Question",
          name: question,
          acceptedAnswer: { "@type": "Answer", text: answer },
        })),
      })}
    />
  </Fragment>
  <!-- HERO -->
  <Container>
    <Hero
      eyebrow={hero.eyebrow}
      heading={hero.heading}
      subheading={heroSubheading}
      body={hero.body}
      chips={hero.chips ?? undefined}
      actions={heroActions}
    />
  </Container>

  <!-- OPERATIONS -->
  <section
    id="tools"
    style="border-top:1px solid var(--th-color-border-default)"
  >
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow={sh["home--operations"]?.eyebrow}
          title={titleToReact(sh["home--operations"]?.title ?? "")}
          intro={sh["home--operations"]?.intro}
          style={ss}
        />
        <div class="op-grid">
          {
            operations.map((op, i) => (
              <div>
                <OpCard
                  name={op.title}
                  description={op.detail}
                  credits={op.creditCost}
                  href={op.active ? op.actionRoute : undefined}
                  ctaLabel={op.actionLabel}
                  icon={iconMap[op.iconKey]}
                  iconVariant={deriveVariant(op, i)}
                  status={op.active ? "live" : "soon"}
                />
              </div>
            ))
          }
        </div>
      </Section>
    </Container>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" style={borderStyle}>
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow={sh["home--how-it-works"]?.eyebrow}
          title={titleToReact(sh["home--how-it-works"]?.title ?? "")}
          style={ss}
        />
        <AutoGrid minColWidth="240px" gap={4}>
          {
            steps.map(({ id, number, title, body }) => (
              <StepCard number={number} title={title} body={body} />
            ))
          }
        </AutoGrid>
      </Section>
    </Container>
  </section>

  <!-- PRICING -->
  <section id="pricing" style={borderStyle}>
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow={sh["home--pricing"]?.eyebrow}
          title={titleToReact(sh["home--pricing"]?.title ?? "")}
          intro={sh["home--pricing"]?.intro}
          style={ss}
        />
        <Pricing client:load />
      </Section>
    </Container>
  </section>

  <!-- TESTIMONIALS -->
  <section style={borderStyle}>
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow={sh["home--testimonials"]?.eyebrow}
          title={titleToReact(sh["home--testimonials"]?.title ?? "")}
          style={ss}
        />
        <AutoGrid minColWidth="280px" gap={4}>
          {
            testimonials.map(({ detail, name, title }) => (
              <TestimonialCard
                quote={detail}
                attribution={`${name} · ${title}`}
              />
            ))
          }
        </AutoGrid>
      </Section>
    </Container>
  </section>

  <!-- FAQ -->
  <section id="faq" style={borderStyle}>
    <Container>
      <Section size="md">
        <SectionHeader
          eyebrow={sh["home--faq"]?.eyebrow}
          title={titleToReact(sh["home--faq"]?.title ?? "")}
          style={ss}
        />
        <div style="max-width:680px">
          <Accordion client:load items={faqItems} defaultOpenIndex={0} />
        </div>
      </Section>
    </Container>
  </section>

  <!-- CTA STRIP -->
  <section style={borderStyle}>
    <Container>
      <Section size="md">
        <DarkStrip
          eyebrow="Ready to get started"
          heading={ctaHeading}
          body="Create a free account and process your first PDF in under a minute."
          align="center"
          actions={ctaAction}
        />
      </Section>
    </Container>
  </section>
</Layout>

<style is:global>
  .op-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  @media (max-width: 900px) {
    .op-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .op-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
