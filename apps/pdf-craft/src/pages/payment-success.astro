---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="page">
    <div class="card">

      <div class="icon-wrap">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>

      <div class="content">
        <h1 class="title">Payment successful</h1>
        <p class="body">
          Your credits have been added to your account and are ready to use right away.
        </p>
      </div>

      <div class="tools-panel">
        <p class="tools-label">Your credits work across</p>
        <ul class="tools-list">
          <li>Merge PDFs</li>
          <li>Image to PDF</li>
          <li>Encrypt &amp; decrypt PDFs</li>
        </ul>
      </div>

      <div class="actions">
        <a href="/dashboard" class="btn-primary">Go to dashboard</a>
        <a href="/buy-credits" class="btn-ghost">Buy more credits</a>
      </div>

    </div>
  </div>
</Layout>

<script>
  import { logEvent } from '../utils/lib/analytics';
  logEvent('purchase', { currency: 'USD' });
</script>

<style>
  .page {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: var(--th-space-16) var(--th-space-6);
    min-height: 60vh;
  }

  .card {
    width: 100%;
    max-width: 480px;
    background: var(--th-color-surface-1);
    border: 1px solid var(--th-color-border-default);
    border-radius: var(--th-radius-xl);
    padding: var(--th-space-10) var(--th-space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--th-space-6);
    text-align: center;
    box-shadow: var(--th-shadow-md);
  }

  .icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--th-color-success-subtle);
    color: var(--th-color-success-text);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--th-space-3);
  }

  .title {
    font-family: var(--th-font-serif);
    font-size: var(--th-text-2xl);
    font-weight: 400;
    color: var(--th-color-text-1);
    line-height: 1.2;
    margin: 0;
  }

  .body {
    font-family: var(--th-font-display);
    font-size: var(--th-text-base);
    color: var(--th-color-text-2);
    line-height: 1.6;
    margin: 0;
  }

  .tools-panel {
    width: 100%;
    background: var(--th-color-surface-2);
    border-radius: var(--th-radius-lg);
    padding: var(--th-space-5) var(--th-space-6);
    display: flex;
    flex-direction: column;
    gap: var(--th-space-3);
    text-align: left;
  }

  .tools-label {
    font-family: var(--th-font-display);
    font-size: var(--th-text-sm);
    font-weight: 600;
    color: var(--th-color-text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }

  .tools-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--th-space-2);
  }

  .tools-list li {
    font-family: var(--th-font-display);
    font-size: var(--th-text-base);
    color: var(--th-color-text-1);
    display: flex;
    align-items: center;
    gap: var(--th-space-3);
  }

  .tools-list li::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--th-color-accent);
    flex-shrink: 0;
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: var(--th-space-3);
    width: 100%;
  }

  .btn-primary,
  .btn-ghost {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--th-space-3) var(--th-space-6);
    border-radius: var(--th-radius-md);
    font-family: var(--th-font-display);
    font-size: var(--th-text-base);
    font-weight: 600;
    text-decoration: none;
    transition:
      background var(--th-duration-base) var(--th-ease-out),
      color var(--th-duration-base) var(--th-ease-out),
      border-color var(--th-duration-base) var(--th-ease-out);
    cursor: pointer;
  }

  .btn-primary {
    background: var(--th-color-text-1);
    color: var(--th-color-text-inverse);
    border: 2px solid var(--th-color-text-1);
  }

  .btn-primary:hover {
    background: var(--th-color-accent);
    border-color: var(--th-color-accent);
  }

  .btn-ghost {
    background: transparent;
    color: var(--th-color-text-2);
    border: 2px solid var(--th-color-border-strong);
  }

  .btn-ghost:hover {
    border-color: var(--th-color-text-2);
    color: var(--th-color-text-1);
  }

  @media (max-width: 480px) {
    .page {
      padding: var(--th-space-8) var(--th-space-4);
    }

    .card {
      padding: var(--th-space-8) var(--th-space-5);
    }
  }
</style>
