---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="page">
    <div class="card">

      <div class="icon-wrap">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </div>

      <div class="content">
        <h1 class="title">Payment cancelled</h1>
        <p class="body">
          No worries — your payment was not processed and no charges were made.
        </p>
      </div>

      <div class="note">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4M12 8h.01"/>
        </svg>
        <p>Your account and any existing credits are untouched. Credits are only deducted when an operation completes successfully.</p>
      </div>

      <div class="actions">
        <a href="/buy-credits" class="btn-primary">Try again</a>
        <a href="/dashboard" class="btn-ghost">Back to dashboard</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .page {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: var(--th-space-16) var(--th-space-6);
    min-height: 60vh;
  }

  .card {
    width: 100%;
    max-width: 480px;
    background: var(--th-color-surface-1);
    border: 1px solid var(--th-color-border-default);
    border-radius: var(--th-radius-xl);
    padding: var(--th-space-10) var(--th-space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--th-space-6);
    text-align: center;
    box-shadow: var(--th-shadow-md);
  }

  .icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--th-color-surface-3);
    color: var(--th-color-text-2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--th-space-3);
  }

  .title {
    font-family: var(--th-font-serif);
    font-size: var(--th-text-2xl);
    font-weight: 400;
    color: var(--th-color-text-1);
    line-height: 1.2;
    margin: 0;
  }

  .body {
    font-family: var(--th-font-display);
    font-size: var(--th-text-base);
    color: var(--th-color-text-2);
    line-height: 1.6;
    margin: 0;
  }

  .note {
    width: 100%;
    background: var(--th-color-surface-2);
    border-radius: var(--th-radius-lg);
    border-left: 3px solid var(--th-color-border-strong);
    padding: var(--th-space-4) var(--th-space-5);
    display: flex;
    gap: var(--th-space-3);
    align-items: flex-start;
    text-align: left;
    color: var(--th-color-text-3);
    flex-shrink: 0;
  }

  .note svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .note p {
    font-family: var(--th-font-display);
    font-size: var(--th-text-sm);
    color: var(--th-color-text-2);
    line-height: 1.6;
    margin: 0;
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: var(--th-space-3);
    width: 100%;
  }

  .btn-primary,
  .btn-ghost {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--th-space-3) var(--th-space-6);
    border-radius: var(--th-radius-md);
    font-family: var(--th-font-display);
    font-size: var(--th-text-base);
    font-weight: 600;
    text-decoration: none;
    transition:
      background var(--th-duration-base) var(--th-ease-out),
      color var(--th-duration-base) var(--th-ease-out),
      border-color var(--th-duration-base) var(--th-ease-out);
    cursor: pointer;
  }

  .btn-primary {
    background: var(--th-color-text-1);
    color: var(--th-color-text-inverse);
    border: 2px solid var(--th-color-text-1);
  }

  .btn-primary:hover {
    background: var(--th-color-accent);
    border-color: var(--th-color-accent);
  }

  .btn-ghost {
    background: transparent;
    color: var(--th-color-text-2);
    border: 2px solid var(--th-color-border-strong);
  }

  .btn-ghost:hover {
    border-color: var(--th-color-text-2);
    color: var(--th-color-text-1);
  }

  @media (max-width: 480px) {
    .page {
      padding: var(--th-space-8) var(--th-space-4);
    }

    .card {
      padding: var(--th-space-8) var(--th-space-5);
    }
  }
</style>
