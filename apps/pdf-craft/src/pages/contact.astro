---
import Layout from "../layouts/Layout.astro";
import { ContactForm } from "../components";
import "../styles/contact.css";
---

<Layout
  title="Contact — PDF Craft"
  description="Get in touch with the PDF Craft team. We typically respond within 1–2 business days."
>
  <div class="contact-page">
    <div class="contact-container">
      <div class="contact-grid">
        <!-- Left: info panel -->
        <div class="contact-info">
          <span class="contact-eyebrow">Support</span>
          <h1 class="contact-title">Get in touch</h1>
          <p class="contact-intro">
            Have a question about your account, a billing issue, or just want to
            share feedback? We'd love to hear from you.
          </p>

          <div class="contact-details">
            <div class="contact-detail-item">
              <div class="contact-detail-icon">✉</div>
              <div>
                <p class="contact-detail-label">Email us directly</p>
                <a
                  href="mailto:support@pdf-craft.app"
                  class="contact-detail-value"
                >
                  support@pdf-craft.app
                </a>
              </div>
            </div>

            <div class="contact-detail-item">
              <div class="contact-detail-icon">⏱</div>
              <div>
                <p class="contact-detail-label">Response time</p>
                <p class="contact-detail-value">Within 1–2 business days</p>
              </div>
            </div>
          </div>

          <div class="contact-links">
            <p class="contact-links-label">Helpful links</p>
            <ul class="contact-links-list">
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms &amp; Conditions</a></li>
              <li><a href="/buy-credits">Buy credits</a></li>
            </ul>
          </div>
        </div>

        <!-- Right: form -->
        <div class="contact-form-panel">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </div>
</Layout>
