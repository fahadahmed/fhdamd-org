---
import Layout from "../layouts/Layout.astro";
import { SignupForm } from "../components";
import "../styles/auth.css";
---

<Layout
  title="Create an account — PDF-Craft"
  description="Sign up free and start processing PDFs in seconds. No credit card required. Pay only for what you use."
>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-header">
        <h1 class="auth-title">Create an account</h1>
        <p class="auth-subtitle">Start processing PDFs — pay only for what you use</p>
      </div>

      <SignupForm client:load />

      <p class="auth-footer-link">
        Already have an account? <a href="/signin">Sign in</a>
      </p>
    </div>
  </div>
</Layout>

