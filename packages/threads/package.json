{
  "name": "@fhdamd/threads",
  "version": "0.3.0",
  "private": false,
  "license": "MIT",
  "description": "Earthy, accessible React + CSS Modules design system for fhdamd products",
  "keywords": [
    "design-system",
    "react",
    "css-modules",
    "components",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fahadahmed/fhdamd-org",
    "directory": "packages/threads"
  },
  "homepage": "https://fhdamd-threads.web.app",
  "bugs": {
    "url": "https://github.com/fahadahmed/fhdamd-org/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css",
    "./tokens": "./src/tokens/tokens.css"
  },
  "files": [
    "dist",
    "src/tokens/tokens.css",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:all": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "happy-dom": "^17.4.4",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "eslint": "^9.34.0",
    "eslint-plugin-storybook": "^10.4.1",
    "typescript-eslint": "^8.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "storybook": "^10.4.1",
    "typescript": "5.9.2",
    "vitest": "^3.2.4",
    "@vitest/browser": "^3.2.4",
    "playwright": "^1.56.0",
    "@vitest/coverage-v8": "^3.2.4"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
